# ==========================================
# JEWELLOSOFT ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# DO NOT ADD REAL SECRETS TO THIS FILE!
# Copy this file to .env and insert your real keys.
# The .env file is safely ignored by Git.

# --- Backend (Django) ---
# Set to False in production
DEBUG=True

# Must be a long, random, secret string in production
DJANGO_SECRET_KEY=replace-this-with-a-secure-secret-key-in-production

# Custom path for data/db/media (Optional, used mostly by Electron packaging)
# JEWELLOSOFT_DATA_PATH=/absolute/path/to/data/dir

# Database (Currently using SQLite default, but URL format here)
# DATABASE_URL=postgres://user:pass@localhost:5432/jewellosoft

# --- Frontend & Supabase (If applicable) ---
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here
