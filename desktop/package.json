{
  "name": "jewello-soft",
  "version": "1.0.0",
  "description": "JewelloSoft — Professional Jewelry Billing & Inventory Management",
  "main": "main.js",
  "author": "JewelloSoft",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:publish": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.jewellosoft.desktop",
    "productName": "JewelloSoft",
    "copyright": "Copyright © 2026 JewelloSoft",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "publisherName": "JewelloSoft"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JewelloSoft",
      "runAfterFinish": true,
      "installerIcon": "build/icon.png",
      "uninstallerIcon": "build/icon.png",
      "installerHeaderIcon": "build/icon.png",
      "deleteAppDataOnUninstall": false
    },
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": ".",
        "filter": [
          "backend.exe"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "SudeeptoBhakat",
      "repo": "Jewellosoft",
      "releaseType": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "crash.html",
      "build/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3"
  }
}
